<ModelBehaviors>
    <Template Name="HorizonSim_B789_COM_Accept_Template">
        <Parameters Type="Default">
            <NODE_ID>COM_Push_Accept_#ID#</NODE_ID>
			<NODE_ID_DECAL>HS_787_GLARESHIELD_ACCEPT</NODE_ID_DECAL>
			<ANIM_NAME_BUTTON>COM_Push_Accept_#ID#</ANIM_NAME_BUTTON>
			<EVENT_NAME>HS_787_GLARESHIELD_ACCEPT</EVENT_NAME>
			<WWISE_EVENT_1>battery_switch_on</WWISE_EVENT_1>
            <WWISE_EVENT_2>battery_switch_off</WWISE_EVENT_2>
			<ON_PUSH_EVENT/>
        </Parameters>
        <UseTemplate Name="ASOBO_AIRLINER_Base_Template">
            <IE_NAME>COMM_#ID#_Button_ACPT</IE_NAME>
			<INTERACTION_TYPE>Push</INTERACTION_TYPE>
			<SET_STATE_EXTERNAL>if{ (&gt;H:#EVENT_NAME#) #ON_PUSH_EVENT# }</SET_STATE_EXTERNAL>
			<ANIM_NAME>#ANIM_NAME_BUTTON#</ANIM_NAME>
        </UseTemplate>
    </Template>
