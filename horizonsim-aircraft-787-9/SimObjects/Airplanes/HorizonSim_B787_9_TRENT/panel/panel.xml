    <Annunciation>
      <Type>Caution</Type>
      <Text>AIRSPEED LOW</Text>
      <Condition>
        <And>
          <Greater>
            <Simvar name="PLANE ALT ABOVE GROUND MINUS CG" unit="Knots"/>
            <Constant>10</Constant>
          </Greater>
          <Lower>
            <Simvar name="AIRSPEED INDICATED" unit="Knots"/>
            <Gamevar name="AIRCRAFT STALL PROTECTION SPEED MIN" unit="Knots"/>
          </Lower>
        </And>
      </Condition>
    </Annunciation>
