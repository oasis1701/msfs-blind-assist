#!/bin/sh

repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"
if [ -z "$repo_root" ]; then
  exit 0
fi

cd "$repo_root" || exit 0

branch="$(git branch --show-current)"

case "$branch" in
  ""|main|master|build)
    exit 0
    ;;
esac

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File "tools/update_build_branch.ps1" -SourceBranch "$branch" || true
elif command -v powershell.exe >/dev/null 2>&1; then
  powershell.exe -NoProfile -ExecutionPolicy Bypass -File "tools/update_build_branch.ps1" -SourceBranch "$branch" || true
else
  echo "[build hook] PowerShell not found; build branch was not updated."
fi

exit 0
